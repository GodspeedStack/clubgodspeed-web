# =====================================================
# GODSPEED COMMS CENTER - ENVIRONMENT VARIABLES
# =====================================================
# Copy this file to .env and fill in your actual values
# =====================================================

# ---------------------------------
# SUPABASE CONFIGURATION
# ---------------------------------
# Get these from: https://app.supabase.com/project/_/settings/api

# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous/public key (safe to expose in frontend)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ---------------------------------
# RESEND EMAIL CONFIGURATION
# ---------------------------------
# Get your API key from: https://resend.com/api-keys

# Resend API key for sending emails
VITE_RESEND_API_KEY=re_your_api_key_here

# ---------------------------------
# FIREBASE CONFIGURATION (Existing)
# ---------------------------------
# Your existing Firebase configuration
# (Keep your current Firebase settings here)

# ---------------------------------
# NOTES
# ---------------------------------
# 1. VITE_ prefix is required for Vite to expose these to the frontend
# 2. Never commit the actual .env file to version control
# 3. Add .env to your .gitignore file
# 4. For production, set these in your hosting platform's environment variables
